# Project
NODE_ENV=production

# Public ports exposed on the host
NGINX_PORT=8080
FRONTEND_PORT=3000
BACKEND_PORT=5000
POSTGRES_PORT=5432

# PostgreSQL
POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=change_me_strong_password

# Backend database connection
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lms_db
DB_USER=lms_user
DB_PASSWORD=change_me_strong_password

# App secrets
JWT_SECRET=change_me_to_a_long_random_secret

# Development file watching (recommended for Docker Desktop on Windows/macOS)
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true

# Internal backend URL used by Next.js dev rewrites (Docker network hostname)
INTERNAL_API_URL=http://backend:5000
